# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (email) ───────────────────────────────────────────────────────────
# 1. Crear cuenta en https://resend.com
# 2. Ir a Domains → Add Domain → ingresar el dominio (ej: felitostudios.com)
# 3. Resend mostrará los registros DNS a agregar. Ejemplo:
#
#    Tipo   Nombre                          Valor
#    ────   ──────────────────────────────  ──────────────────────────────────
#    MX     send.felitostudios.com          feedback-smtp.us-east-1.amazonses.com (priority 10)
#    TXT    resend._domainkey.felitostudios.com   "p=MIGfMA0GCSqGSIb3..."  (DKIM)
#    TXT    felitostudios.com               "v=spf1 include:amazonses.com ~all"  (SPF)
#    CNAME  em1234.felitostudios.com        u1234.wl.sendgrid.net (tracking, opcional)
#
#    Los valores exactos los da Resend al agregar el dominio.
#    Una vez que Resend muestre "Verified", el dominio está listo.
#
# 4. En Resend → API Keys → crear una clave y copiarla abajo.
# 5. El FROM debe usar el dominio verificado:
#    RESEND_FROM_EMAIL=Felito Barber Studio <turnos@felitostudios.com>
#
# ⚠️  Si RESEND_FROM_EMAIL no está configurado, los emails SOLO llegan al
#     dueño de la cuenta Resend (modo sandbox). Los clientes NO los recibirán.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Felito Barber Studio <turnos@felitostudios.com>

# Email del admin que recibe notificaciones de nuevas reservas
ADMIN_EMAIL=admin@felitostudios.com

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública de la app (usada en links de emails y metadata SEO)
NEXT_PUBLIC_APP_URL=https://felitostudios.com

# ─── Roles ───────────────────────────────────────────────────────────────────
# UUID del usuario superadmin en Supabase Auth
# Encontralo en Supabase > Authentication > Users
SUPERADMIN_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
