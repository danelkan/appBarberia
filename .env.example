# ==================================================================
# Environment Variables — Barbershop Platform
# Copy to .env.local and fill in your values.
# ==================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Project URL from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (KEEP SECRET — server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────
# Public URL of this deployment (used for email links, SEO, OG tags)
NEXT_PUBLIC_APP_URL=https://mibarberia.com

# Barbershop display name — appears in emails, admin sidebar, page titles
NEXT_PUBLIC_APP_NAME=Felito Barber Studio

# Short location for email footers (optional)
APP_LOCATION=Montevideo, Uruguay

# Support/contact email shown to clients (optional)
APP_SUPPORT_EMAIL=contacto@mibarberia.com

# Timezone used for booking availability calculations (optional, defaults to America/Montevideo)
# Must be a valid IANA timezone string: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
APP_TIMEZONE=America/Montevideo

# ── Email (Resend) ────────────────────────────────────────────────
# API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender address (must match a verified domain in Resend)
# Format: "Display Name <address@yourdomain.com>"
# Without this, emails only reach the Resend account owner (sandbox mode)
RESEND_FROM_EMAIL=Mi Barbería <noreply@mibarberia.com>

# ── Push notifications (Web Push / VAPID) ─────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-side alias also supported. Set either this or NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:contacto@mibarberia.com

# ── Platform Access ───────────────────────────────────────────────
# UUID of the superadmin user from Supabase Auth > Users
# This user always has full platform access regardless of user_roles table
# To find it: Supabase Dashboard > Authentication > Users > copy UUID
SUPERADMIN_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: email address that always gets admin role (backup access method)
ADMIN_EMAIL=tu@email.com
